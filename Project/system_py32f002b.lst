  90:../Src/system_py32f002b.c ****  */
  91:../Src/system_py32f002b.c **** void SystemCoreClockUpdate(void)             /* Get Core Clock Frequency      */
  92:../Src/system_py32f002b.c **** {
  93:../Src/system_py32f002b.c ****   uint32_t tmp;
  94:../Src/system_py32f002b.c ****   uint32_t hsidiv;
  95:../Src/system_py32f002b.c ****   uint32_t hsifs;
  96:../Src/system_py32f002b.c **** 
  97:../Src/system_py32f002b.c ****   /* Get SYSCLK source -------------------------------------------------------*/
  98:../Src/system_py32f002b.c ****   switch (RCC->CFGR & RCC_CFGR_SWS)
  99:../Src/system_py32f002b.c ****   {
 100:../Src/system_py32f002b.c ****   case RCC_CFGR_SWS_0:  /* HSE used as system clock */
 101:../Src/system_py32f002b.c ****     SystemCoreClock = HSE_VALUE;
 102:../Src/system_py32f002b.c ****     break;
 103:../Src/system_py32f002b.c **** 
 104:../Src/system_py32f002b.c ****   case (RCC_CFGR_SWS_1 | RCC_CFGR_SWS_0):  /* LSI used as system clock */
 105:../Src/system_py32f002b.c ****     SystemCoreClock = LSI_VALUE;
 106:../Src/system_py32f002b.c ****     break;
 107:../Src/system_py32f002b.c **** #if defined(RCC_LSE_SUPPORT)
 108:../Src/system_py32f002b.c ****   case RCC_CFGR_SWS_2:  /* LSE used as system clock */
 109:../Src/system_py32f002b.c ****     SystemCoreClock = LSE_VALUE;
 110:../Src/system_py32f002b.c ****     break;
 111:../Src/system_py32f002b.c **** #endif /* RCC_LSE_SUPPORT */
 112:../Src/system_py32f002b.c ****   case 0x00000000U:  /* HSI used as system clock */
 113:../Src/system_py32f002b.c ****   default:                /* HSI used as system clock */
 114:../Src/system_py32f002b.c ****     hsifs = ((READ_BIT(RCC->ICSCR, RCC_ICSCR_HSI_FS)) >> RCC_ICSCR_HSI_FS_Pos);
 115:../Src/system_py32f002b.c ****     hsidiv = (1UL << ((READ_BIT(RCC->CR, RCC_CR_HSIDIV)) >> RCC_CR_HSIDIV_Pos));
 116:../Src/system_py32f002b.c ****     SystemCoreClock = (HSIFreqTable[hsifs] / hsidiv);
 117:../Src/system_py32f002b.c ****     break;
 118:../Src/system_py32f002b.c ****   }
 119:../Src/system_py32f002b.c ****   /* Compute HCLK clock frequency --------------------------------------------*/
 120:../Src/system_py32f002b.c ****   /* Get HCLK prescaler */
 121:../Src/system_py32f002b.c ****   tmp = AHBPrescTable[((RCC->CFGR & RCC_CFGR_HPRE) >> RCC_CFGR_HPRE_Pos)];
 122:../Src/system_py32f002b.c ****   /* HCLK clock frequency */
 123:../Src/system_py32f002b.c ****   SystemCoreClock >>= tmp;
 124:../Src/system_py32f002b.c **** }
