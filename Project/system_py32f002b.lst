 147:../Src/system_py32f002b.c **** #ifndef SWD_DELAY
 148:../Src/system_py32f002b.c ****   /* When the SWD pin is reused for other functions, this function is used to solve the 
 149:../Src/system_py32f002b.c ****   problem of not being able to update the code. */
 150:../Src/system_py32f002b.c ****   DelayTime(200);
 151:../Src/system_py32f002b.c **** #endif /* SWD_DELAY */
 152:../Src/system_py32f002b.c **** }
