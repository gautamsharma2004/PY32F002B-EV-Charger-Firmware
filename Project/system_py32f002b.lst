  63:../Src/system_py32f002b.c **** /* This variable is updated in three ways:
  64:../Src/system_py32f002b.c ****     1) by calling CMSIS function SystemCoreClockUpdate()
  65:../Src/system_py32f002b.c ****     2) by calling HAL API function HAL_RCC_GetHCLKFreq()
  66:../Src/system_py32f002b.c ****     3) each time HAL_RCC_ClockConfig() is called to configure the system clock frequency
  67:../Src/system_py32f002b.c ****        Note: If you use this function to configure the system clock; then there
  68:../Src/system_py32f002b.c ****              is no need to call the 2 first functions listed above, since SystemCoreClock
  69:../Src/system_py32f002b.c ****              variable is updated automatically.
  70:../Src/system_py32f002b.c **** */
  71:../Src/system_py32f002b.c **** uint32_t SystemCoreClock = HSI_VALUE;
  72:../Src/system_py32f002b.c **** 
  73:../Src/system_py32f002b.c **** const uint32_t AHBPrescTable[16] = {0, 0, 0, 0, 0, 0, 0, 0, 1, 2, 3, 4, 6, 7, 8, 9};
  74:../Src/system_py32f002b.c **** const uint32_t APBPrescTable[8] =  {0, 0, 0, 0, 1, 2, 3, 4};
  75:../Src/system_py32f002b.c **** #if defined(RCC_HSI48M_SUPPORT)
  76:../Src/system_py32f002b.c **** const uint32_t HSIFreqTable[8] = {4000000U, 8000000U, 0U, 0U, 24000000U, 48000000U, 0U, 0U};
  77:../Src/system_py32f002b.c **** #else
  78:../Src/system_py32f002b.c **** const uint32_t HSIFreqTable[8] = {4000000U, 8000000U, 0U, 0U, 24000000U, 0U, 0U, 0U};
  79:../Src/system_py32f002b.c **** #endif
