 126:../Src/system_py32f002b.c **** /**
 127:../Src/system_py32f002b.c ****  * @brief  Setup the microcontroller system.
 128:../Src/system_py32f002b.c ****  *         Initialize the System.
 129:../Src/system_py32f002b.c ****  * @param  none
 130:../Src/system_py32f002b.c ****  * @return none
 131:../Src/system_py32f002b.c ****  */
 132:../Src/system_py32f002b.c **** void SystemInit(void)
 133:../Src/system_py32f002b.c **** {
 134:../Src/system_py32f002b.c ****   /*Set the HSI clock to 24MHz by default*/
 135:../Src/system_py32f002b.c ****   RCC->ICSCR = (RCC->ICSCR & 0xFFFF0000) | ((*(uint32_t *)(0x1FFF0100)) & 0xFFFF);
 136:../Src/system_py32f002b.c **** 
 137:../Src/system_py32f002b.c ****   /*Set the LSI clock to 32.768KHz by default*/
 138:../Src/system_py32f002b.c ****   RCC->ICSCR = (RCC->ICSCR & 0xFE00FFFF) | (((*(uint32_t *)(0x1FFF0144)) & 0x1FF) << RCC_ICSCR_LSI_
 139:../Src/system_py32f002b.c **** 
 140:../Src/system_py32f002b.c ****   /* Configure the Vector Table location add offset address ------------------*/
 141:../Src/system_py32f002b.c **** #ifdef VECT_TAB_SRAM
 142:../Src/system_py32f002b.c ****   SCB->VTOR = SRAM_BASE | VECT_TAB_OFFSET; /* Vector Table Relocation in Internal SRAM */
 143:../Src/system_py32f002b.c **** #else
 144:../Src/system_py32f002b.c ****   SCB->VTOR = FLASH_BASE | VECT_TAB_OFFSET; /* Vector Table Relocation in Internal FLASH */
 145:../Src/system_py32f002b.c **** #endif /* VECT_TAB_SRAM */
 146:../Src/system_py32f002b.c **** 
