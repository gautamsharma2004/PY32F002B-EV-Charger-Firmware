 190:../Src/main.c ****    Display Manager - 1 Second Tick
 191:../Src/main.c ****    ===================================================== */
 192:../Src/main.c **** 
 193:../Src/main.c **** static void Task_1sec(void)
 194:../Src/main.c **** {
 195:../Src/main.c ****     ChargerState_t state = ChargerSM_GetState();
 196:../Src/main.c ****     
 197:../Src/main.c ****     
 198:../Src/main.c ****     // If in fault state, show fault code
 199:../Src/main.c ****     if (state == STATE_FAULT) {
 200:../Src/main.c ****         g_display_mode = DISPLAY_FAULT_CODE;
 201:../Src/main.c ****     }
 202:../Src/main.c ****     // If menu is active, show menu
 203:../Src/main.c ****     else if (Menu_IsActive()) {
 204:../Src/main.c ****         g_display_mode = DISPLAY_MENU;
 205:../Src/main.c ****     }
 206:../Src/main.c ****     // During charging, alternate between voltage and SOC
 207:../Src/main.c ****     else if (ChargerSM_IsCharging()) {
 208:../Src/main.c ****         g_display_timer++;
