 210:../Src/main.c ****             g_display_timer = 0;
 211:../Src/main.c ****             g_display_mode = (g_display_mode == DISPLAY_VOLTAGE) 
 212:../Src/main.c ****                            ? DISPLAY_SOC : DISPLAY_VOLTAGE;
 213:../Src/main.c ****         }
 214:../Src/main.c ****     }
