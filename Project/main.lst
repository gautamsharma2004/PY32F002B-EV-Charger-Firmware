 225:../Src/main.c **** static void UpdateDisplay(void)
ARM GAS  C:\Users\Gautam\AppData\Local\Temp\cchduyDh.s 			page 26


 226:../Src/main.c **** {
 227:../Src/main.c ****     ADCMeasurement_t meas = ADC_GetMeasurement();
 228:../Src/main.c ****     uint8_t soc = SOC_GetDisplaySOC();
 229:../Src/main.c ****     
 230:../Src/main.c ****     switch (g_display_mode) {
 231:../Src/main.c ****         case DISPLAY_VOLTAGE: {
 232:../Src/main.c ****             // Display battery voltage (TM1637_DisplayVoltage expects 0.01V units)
 233:../Src/main.c ****             TM1637_DisplayVoltage((uint16_t)(meas.vbat_mv / 10));
 234:../Src/main.c ****             break;
 235:../Src/main.c ****         }
 236:../Src/main.c ****         case DISPLAY_CURRENT: {
 237:../Src/main.c ****             uint16_t amps = meas.ibat_ma / 1000;
 238:../Src/main.c ****             TM1637_DisplayNumber(amps);
 239:../Src/main.c ****             break;
 240:../Src/main.c ****         }
 241:../Src/main.c ****         case DISPLAY_SOC: {
 242:../Src/main.c ****             if (SOC_IsQualified()) {
 243:../Src/main.c ****                 TM1637_DisplayNumber(soc);
 244:../Src/main.c ****             } else {
 245:../Src/main.c ****                 TM1637_DisplayNumber(soc);  // Keep showing old value during qualification
 246:../Src/main.c ****             }
 247:../Src/main.c ****             break;
 248:../Src/main.c ****         }
 249:../Src/main.c ****         case DISPLAY_FAULT_CODE: {
 250:../Src/main.c ****             FaultCode_t fault = ChargerSM_GetFault();
 251:../Src/main.c ****             TM1637_DisplayNumber((uint16_t)fault);
 252:../Src/main.c ****             break;
 253:../Src/main.c ****         }
 254:../Src/main.c ****         case DISPLAY_MENU: {
 255:../Src/main.c ****             Menu_UpdateDisplay();
 256:../Src/main.c ****             break;
 257:../Src/main.c ****         }
 258:../Src/main.c ****     }
 259:../Src/main.c **** }
