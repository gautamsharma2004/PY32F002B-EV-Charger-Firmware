  20:../Src/charger_adc.c **** /* =====================================================
  21:../Src/charger_adc.c ****    NTC Temperature Lookup Table
  22:../Src/charger_adc.c ****    ===================================================== 
  23:../Src/charger_adc.c ****    
  24:../Src/charger_adc.c ****    10kΩ NTC thermistor (typically B=3950K)
  25:../Src/charger_adc.c ****    ADC reference: 3.3V, 12-bit resolution (0-4095 counts)
  26:../Src/charger_adc.c ****    10k pullup resistor
  27:../Src/charger_adc.c ****    
  28:../Src/charger_adc.c ****    Table: ADC count → Temperature in 0.1°C units
  29:../Src/charger_adc.c ****    
  30:../Src/charger_adc.c ****    Typical NTC characteristics:
  31:../Src/charger_adc.c ****    - At 25°C: ~2000 ADC counts (1.6V across NTC)
  32:../Src/charger_adc.c ****    - At 80°C: ~800 ADC counts (0.64V across NTC)
ARM GAS  C:\Users\Gautam\AppData\Local\Temp\ccwiy1cV.s 			page 2


  33:../Src/charger_adc.c ****    - At 90°C: ~600 ADC counts (0.48V across NTC)
  34:../Src/charger_adc.c ****    
  35:../Src/charger_adc.c ****    This is a simplified lookup. For production, use Steinhart-Hart equation.
  36:../Src/charger_adc.c ****    
  37:../Src/charger_adc.c ****    ===================================================== */
  38:../Src/charger_adc.c **** 
  39:../Src/charger_adc.c **** static const struct {
  40:../Src/charger_adc.c ****     uint16_t adc;    // ADC count
  41:../Src/charger_adc.c ****     uint16_t temp;   // Temperature in 0.1°C (e.g., 250 = 25.0°C)
  42:../Src/charger_adc.c **** } ntc_lookup[] = {
  43:../Src/charger_adc.c ****     // Format: { ADC_count, Temp_x10 }
  44:../Src/charger_adc.c ****     // Decreasing ADC → Increasing Temperature
  45:../Src/charger_adc.c ****     {3800, 0},       // -40°C (below practical range)
  46:../Src/charger_adc.c ****     {3500, 100},     // 10°C
  47:../Src/charger_adc.c ****     {3000, 250},     // 25°C (typical room temp)
  48:../Src/charger_adc.c ****     {2500, 400},     // 40°C
  49:../Src/charger_adc.c ****     {2000, 550},     // 55°C
  50:../Src/charger_adc.c ****     {1500, 700},     // 70°C
  51:../Src/charger_adc.c ****     {1000, 800},     // 80°C
  52:../Src/charger_adc.c ****     {800,  900},     // 90°C (shutdown threshold)
  53:../Src/charger_adc.c ****     {600,  1000},    // 100°C
  54:../Src/charger_adc.c ****     {400,  1100},    // 110°C
  55:../Src/charger_adc.c **** };
  56:../Src/charger_adc.c **** 
  57:../Src/charger_adc.c **** #define NTC_LOOKUP_SIZE (sizeof(ntc_lookup) / sizeof(ntc_lookup[0]))
  58:../Src/charger_adc.c **** 
  59:../Src/charger_adc.c **** /* =====================================================
  60:../Src/charger_adc.c ****    Helper: Median of 3 values
  61:../Src/charger_adc.c ****    ===================================================== */
  62:../Src/charger_adc.c **** 
  63:../Src/charger_adc.c **** static uint16_t Median3(uint16_t a, uint16_t b, uint16_t c)
  64:../Src/charger_adc.c **** {
  65:../Src/charger_adc.c ****     if (a > b) {
  66:../Src/charger_adc.c ****         if (b > c) return b;           // a > b > c
  67:../Src/charger_adc.c ****         else if (a > c) return c;      // a > c >= b
  68:../Src/charger_adc.c ****         else return a;                  // c >= a > b
  69:../Src/charger_adc.c ****     } else {
  70:../Src/charger_adc.c ****         if (a > c) return a;           // b >= a > c
  71:../Src/charger_adc.c ****         else if (b > c) return c;      // b >= c >= a
  72:../Src/charger_adc.c ****         else return b;                  // c >= b >= a
  73:../Src/charger_adc.c ****     }
  74:../Src/charger_adc.c **** }
  75:../Src/charger_adc.c **** 
