 101:../Src/charger_control.c **** /**
 102:../Src/charger_control.c ****  * @brief  Updates the reference voltages fed to the TL494 error amplifiers.
 103:../Src/charger_control.c ****  */
 104:../Src/charger_control.c **** static void Update_TL494_Reference(float voltage_ref, float current_ref)
 105:../Src/charger_control.c **** {
 106:../Src/charger_control.c ****     /* To get EXACTLY 67.0V instead of the hardware default (e.g. 67.2V), 
 107:../Src/charger_control.c ****      * you must output a PWM/DAC signal here to adjust the TL494 Error Amp.
 108:../Src/charger_control.c ****      * If this is empty, the output relies purely on your PCB's resistor divider.
 109:../Src/charger_control.c ****      */
 110:../Src/charger_control.c **** }
 111:../Src/charger_control.c **** 
