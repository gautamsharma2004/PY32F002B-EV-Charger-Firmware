  34:../Src/charger_control.c **** 
  35:../Src/charger_control.c **** /**
  36:../Src/charger_control.c ****  * @brief Disables the TL494 controller by pulling the Dead Time Control (DTC) pin HIGH.
  37:../Src/charger_control.c ****  */
  38:../Src/charger_control.c **** void ChargerCtrl_DisableOutput(void)
  39:../Src/charger_control.c **** {
  40:../Src/charger_control.c ****     HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_SET);
  41:../Src/charger_control.c **** }
  42:../Src/charger_control.c **** 
  43:../Src/charger_control.c **** void ChargerCtrl_Init(void)
  44:../Src/charger_control.c **** {
  45:../Src/charger_control.c ****     currentState = CHARGE_STATE_IDLE;
  46:../Src/charger_control.c ****     config.current_limit = 0.0f;
  47:../Src/charger_control.c ****     
  48:../Src/charger_control.c ****     /* Start safe, then override in Task */
  49:../Src/charger_control.c ****     ChargerCtrl_DisableOutput();
  50:../Src/charger_control.c ****     Update_TL494_Reference(0.0f, 0.0f);
  51:../Src/charger_control.c **** }
  52:../Src/charger_control.c **** 
  53:../Src/charger_control.c **** void ChargerCtrl_SetTargets(float vset, float cset)
  54:../Src/charger_control.c **** {
  55:../Src/charger_control.c ****     config.vset_target = vset;
  56:../Src/charger_control.c ****     config.cset_target = cset;
  57:../Src/charger_control.c **** }
  58:../Src/charger_control.c **** 
  59:../Src/charger_control.c **** void ChargerCtrl_Task(void)
  60:../Src/charger_control.c **** {
  61:../Src/charger_control.c ****     /* 1. Fetch live hardware data from ADC */
  62:../Src/charger_control.c ****     Read_ADC_Channels();
  63:../Src/charger_control.c **** 
  64:../Src/charger_control.c ****     /* 2. Critical Hardware Protections (Kept active for test safety) */
  65:../Src/charger_control.c ****     if (actual_temp >= TEMP_FAULT_THRESHOLD) 
  66:../Src/charger_control.c ****     {
  67:../Src/charger_control.c ****         currentState = CHARGE_STATE_FAULT;
  68:../Src/charger_control.c ****         ChargerCtrl_DisableOutput(); 
  69:../Src/charger_control.c ****     }
  70:../Src/charger_control.c **** 
  71:../Src/charger_control.c ****     if (currentState == CHARGE_STATE_FAULT)
  72:../Src/charger_control.c ****     {
  73:../Src/charger_control.c ****         if (actual_temp <= TEMP_RECOVERY_THRESHOLD)
  74:../Src/charger_control.c ****         {
  75:../Src/charger_control.c ****             currentState = CHARGE_STATE_IDLE; 
  76:../Src/charger_control.c ****         }
  77:../Src/charger_control.c ****         return; 
  78:../Src/charger_control.c ****     }
  79:../Src/charger_control.c **** 
  80:../Src/charger_control.c ****     /* 3. Main State Machine - TEST OVERRIDE */
  81:../Src/charger_control.c ****     switch (currentState)
  82:../Src/charger_control.c ****     {
  83:../Src/charger_control.c ****         case CHARGE_STATE_IDLE:
  84:../Src/charger_control.c ****             /* ⚠️ DANGER: FORCING OUTPUT ON IMMEDIATELY ⚠️ */
  85:../Src/charger_control.c ****             /* Bypassing battery detection (Vset Wake) and Soft Start */
  86:../Src/charger_control.c ****             config.current_limit = config.cset_target; 
  87:../Src/charger_control.c ****             currentState = CHARGE_STATE_CC_CV;
  88:../Src/charger_control.c ****             ChargerCtrl_EnableOutput(); /* Turns on the TL494 */
  89:../Src/charger_control.c ****             break;
  90:../Src/charger_control.c **** 
ARM GAS  C:\Users\Gautam\AppData\Local\Temp\ccCvdGmJ.s 			page 3


  91:../Src/charger_control.c ****         case CHARGE_STATE_CC_CV:
  92:../Src/charger_control.c ****             /* Output is live. Continously update references if using DAC/PWM */
  93:../Src/charger_control.c ****             Update_TL494_Reference(config.vset_target, config.current_limit);
  94:../Src/charger_control.c ****             break;
  95:../Src/charger_control.c **** 
  96:../Src/charger_control.c ****         default:
  97:../Src/charger_control.c ****             break;
  98:../Src/charger_control.c ****     }
  99:../Src/charger_control.c **** }
