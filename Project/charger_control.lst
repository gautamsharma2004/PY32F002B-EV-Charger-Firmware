   6:../Src/charger_control.c ****  */
   7:../Src/charger_control.c **** 
   8:../Src/charger_control.c **** #include "charger_control.h"
   9:../Src/charger_control.c **** #include "main.h"
  10:../Src/charger_control.c **** 
  11:../Src/charger_control.c **** /* Thermal Limits (Celsius) */
  12:../Src/charger_control.c **** #define TEMP_FAULT_THRESHOLD      90.0f
  13:../Src/charger_control.c **** #define TEMP_RECOVERY_THRESHOLD   60.0f
  14:../Src/charger_control.c **** 
  15:../Src/charger_control.c **** static ChargeState_t currentState = CHARGE_STATE_IDLE;
  16:../Src/charger_control.c **** static ChargerConfig_t config = {0};
  17:../Src/charger_control.c **** 
  18:../Src/charger_control.c **** /* ADC Filtered Readings */
  19:../Src/charger_control.c **** static float actual_voltage = 0.0f;
  20:../Src/charger_control.c **** static float actual_current = 0.0f;
  21:../Src/charger_control.c **** static float actual_temp = 25.0f;
  22:../Src/charger_control.c **** 
  23:../Src/charger_control.c **** /* Internal hardware control abstraction */
  24:../Src/charger_control.c **** static void Update_TL494_Reference(float voltage_ref, float current_ref);
  25:../Src/charger_control.c **** static void Read_ADC_Channels(void);
  26:../Src/charger_control.c **** 
  27:../Src/charger_control.c **** /**
  28:../Src/charger_control.c ****  * @brief Enables the TL494 controller by pulling the Dead Time Control (DTC) pin LOW.
  29:../Src/charger_control.c ****  */
  30:../Src/charger_control.c **** void ChargerCtrl_EnableOutput(void)
  31:../Src/charger_control.c **** {
  32:../Src/charger_control.c ****     HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_RESET);
  33:../Src/charger_control.c **** }
